{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /**
     * 构建选项（构建环境）
     */
    "rootDir": "src",
    "outDir": "dist/esm",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/demo.ts"
  ]
}
